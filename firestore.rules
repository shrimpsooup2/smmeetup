rules_version = '2';

// SM Meetup — Firestore security rules.
// Paste this into Firebase console → Firestore Database → Rules → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    // Only verified smtexas.org accounts count as students. Everything in
    // the app requires this, so accounts on other domains can't touch data.
    function isStudent() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower().matches('.*@smtexas[.]org$');
    }

    function activity(activityId) {
      return get(/databases/$(database)/documents/activities/$(activityId)).data;
    }

    function canSeeActivity(a) {
      return a.visibility == 'public'
        || a.hostUid == request.auth.uid
        || request.auth.uid in a.get('visibleTo', []);
    }

    // ── Student profiles ──────────────────────────────────────────────
    // Any student can read profiles (that's how contact info and
    // availability are shared); you can only write your own.
    match /users/{uid} {
      allow read: if isStudent();
      allow create, update: if isStudent() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ── Activities ────────────────────────────────────────────────────
    match /activities/{activityId} {
      // Public activities: everyone. Private: host + invited/joined only.
      allow read: if isStudent() && canSeeActivity(resource.data);

      allow create: if isStudent()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.dates is list
        && request.resource.data.dates.size() > 0
        && request.resource.data.grades is list
        && request.resource.data.grades.size() > 0
        && request.resource.data.visibility in ['public', 'private']
        && (request.resource.data.visibility == 'public'
            || request.auth.uid in request.resource.data.visibleTo);

      // Host can delete any time; anyone can clear out an expired activity
      // (the app does this automatically ~2 months after the last day).
      allow delete: if isStudent() && (
        resource.data.hostUid == request.auth.uid
        || ('expiresAt' in resource.data && request.time > resource.data.expiresAt)
      );

      // The host can update anything. Everyone else may only touch the
      // join/invite-related fields (join, leave, request, cancel, accept or
      // decline an invite), and may not change who the host is.
      allow update: if isStudent() && (
        resource.data.hostUid == request.auth.uid
        || (
          canSeeActivity(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['participants', 'participantNames', 'pending', 'pendingNames',
                      'invited', 'invitedNames', 'visibleTo'])
          && request.resource.data.hostUid == resource.data.hostUid
        )
      );

      // ── Chat / host updates ─────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isStudent() && canSeeActivity(activity(activityId));

        // Post as yourself if you're the host, or if the host enabled
        // participant chat and you're a participant.
        allow create: if isStudent()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && (
            request.auth.uid == activity(activityId).hostUid
            || (
              activity(activityId).allowChat == true
              && request.auth.uid in activity(activityId).participants
            )
          );

        allow update, delete: if false;
      }
    }

    // ── Friend requests ───────────────────────────────────────────────
    // Doc id is always "{fromUid}_{toUid}", so a pair can't spam duplicates.
    match /friendRequests/{requestId} {
      allow read: if isStudent()
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);

      allow create: if isStudent()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && requestId == request.resource.data.from + '_' + request.resource.data.to;

      // sender cancels, or receiver declines / cleans up after accepting
      allow delete: if isStudent()
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);

      allow update: if false;
    }

    // ── Friendships ───────────────────────────────────────────────────
    // Doc id is "{uidA}_{uidB}" with the uids sorted. Created by the person
    // ACCEPTING: there must be a pending request from the other user to them.
    match /friendships/{friendshipId} {
      function otherUser() {
        return request.resource.data.users[0] == request.auth.uid
          ? request.resource.data.users[1]
          : request.resource.data.users[0];
      }

      allow read: if isStudent() && request.auth.uid in resource.data.users;

      allow create: if isStudent()
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users[0] < request.resource.data.users[1]
        && friendshipId == request.resource.data.users[0] + '_' + request.resource.data.users[1]
        && exists(/databases/$(database)/documents/friendRequests/$(otherUser() + '_' + request.auth.uid));

      // either person can unfriend
      allow delete: if isStudent() && request.auth.uid in resource.data.users;

      allow update: if false;
    }
  }
}
